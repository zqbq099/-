rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required, immutable)
    //   - role: string (required, enum: ['user', 'admin'])
    //   - plan: string (required, enum: ['free', 'premium'])
    //   - createdAt: timestamp (required, immutable)
    //
    // Collection: users/{userId}/transformations
    // Document ID: {transformId}
    // Fields:
    //   - appName: string
    //   - htmlCode: string
    //   - isSimulation: boolean
    //   - createdAt: number
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }
    
    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }
    
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "zqbq099@gmail.com" && request.auth.token.email_verified == true));
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUser(data) {
      return hasOnlyAllowedFields(['uid', 'role', 'plan', 'createdAt']) &&
             data.uid is string && data.uid.size() > 0 && data.uid.size() < 100 &&
             data.role in ['user', 'admin'] &&
             data.plan in ['free', 'premium'] &&
             data.createdAt is timestamp;
    }

    function isValidTransformation(data) {
      return data.appName is string && data.appName.size() > 0 && data.appName.size() < 100 &&
             data.htmlCode is string && data.htmlCode.size() > 0 && data.htmlCode.size() < 1000000 &&
             data.isSimulation is bool &&
             data.createdAt is number;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Collection: mystique_apps_data/{appName}/data/{documentId}
    // Used by generated apps for real-time features.
    match /mystique_apps_data/{appName}/data/{documentId} {
      allow read, write: if isAuthenticated();
    }
    
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      
      allow create: if isAuthenticated() && 
                    isOwner(userId) && 
                    isValidUser(request.resource.data) && 
                    uidUnchanged() && 
                    ((request.resource.data.role == 'user') || isAdmin());
                    
      allow update: if isAuthenticated() && 
                    isOwner(userId) && 
                    isValidUser(request.resource.data) && 
                    uidNotModified() && 
                    request.resource.data.createdAt == resource.data.createdAt &&
                    ((request.resource.data.role == resource.data.role) || isAdmin());
                    
      allow delete: if isAdmin();

      match /transformations/{transformId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidTransformation(request.resource.data);
        allow update: if isOwner(userId) && isValidTransformation(request.resource.data) && request.resource.data.createdAt == resource.data.createdAt;
        allow delete: if isOwner(userId);
      }
    }
  }
}

